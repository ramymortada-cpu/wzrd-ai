# ─── RADD API — Example Environment ───────────────────────────────────────────
# Copy to .env and fill real values

# === Environment & AWS Secrets ===
APP_ENV="development"  # "development" | "staging" | "production"
AWS_SECRET_NAME="radd/production/api_secrets"  # Secret name in AWS Secrets Manager
AWS_REGION="me-south-1"  # AWS region (Bahrain)

# NOTE: In production (APP_ENV=production), sensitive values like
# DATABASE_URL, OPENAI_API_KEY, etc. are loaded from AWS Secrets Manager
# automatically. You only need to set APP_ENV, AWS_SECRET_NAME, and AWS_REGION.
# In development, all values are read from this .env file as usual.

# === Monitoring & Alerts ===
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SLACK_ALERT_WEBHOOK=""
SLACK_ALERT_WEBHOOK_URL=""

# === Twilio Voice (COD Shield - Egypt) ===
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""  # Format: +1234567890 (Twilio number)
