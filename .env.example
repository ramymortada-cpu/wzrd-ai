# ═══════════════════════════════════════════════════
# Primo Command Center — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this to .env and fill in your values.

# ── APP ──
NODE_ENV=production
PORT=3000
# Public site URL (custom domain or Railway default)
APP_URL=https://wzzrdai.com
# OAuth redirect base — in production use the same origin as APP_URL
# OAUTH_SERVER_URL=https://wzzrdai.com

# Client — WhatsApp wa.me (digits only, no +). Must match client/public/landing/services.html if you use that page.
VITE_WHATSAPP_E164=201107107012

# Google Analytics 4 Measurement ID (must match gtag id in client/index.html + client/public/landing/*.html)
VITE_GA4_ID=G-20GXRBPFGR

# ── SPRINT 4 NEW VARS ──
# Required for Design Health Check (GPT-4o Vision) and RAG Embeddings
# OPENAI_API_KEY=sk-proj-your-key-here

# PostHog Analytics (optional)
# VITE_POSTHOG_KEY=phc_your_key_here
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Client Sentry (optional — browser error monitoring)
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.us.sentry.io/xxxx

# ── AUTH [REQUIRED] ──
JWT_SECRET=your-random-32-char-secret-here
# Generate with: openssl rand -hex 32

# ── DATABASE [REQUIRED] ──
# Railway MySQL provides this automatically
DATABASE_URL=mysql://user:password@host:port/database

# ═══════════════════════════════════════════════════
# LLM — DUAL PROVIDER SETUP
# ═══════════════════════════════════════════════════
#
# The system uses TWO providers:
#   Groq (PRIMARY)  → free/cheap — chat, research, quality review
#   Claude (PREMIUM) → smart — deliverables, proposals, brand audits
#
# Set BOTH for best results. Or set just ONE — the system adapts.
# ═══════════════════════════════════════════════════

# GROQ — Primary (free tier: no credit card needed!)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Other options: llama-4-maverick-17b-128e-instruct, llama-3.1-8b-instant

# ANTHROPIC CLAUDE — Premium (for client-facing deliverables)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
# Other options: claude-haiku-4-5-20251001 (cheaper, faster)

# ── EMAIL NOTIFICATIONS (optional) ──
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_your_key
# EMAIL_FROM=Primo Marca <noreply@primomarca.com>

# ── WHATSAPP (optional) ──
# WHATSAPP_TOKEN=your-whatsapp-business-api-token
# WHATSAPP_PHONE_ID=your-phone-number-id
# WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ── TELEGRAM (optional) ──
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-bot-token

# ── S3 FILE UPLOADS (optional) ──
# AWS_S3_BUCKET=primo-uploads
# AWS_REGION=me-south-1

# ── PAYMOB PAYMENTS (for credits purchase — Egypt + Saudi) ──
# Get keys at: Paymob Dashboard → Settings → Account Info
# PAYMOB_SECRET_KEY=sk_your_secret_key
# PAYMOB_PUBLIC_KEY=pk_your_public_key
# PAYMOB_HMAC_SECRET=your_hmac_secret
# Get integration IDs from: Paymob Dashboard → Developers → Payment Integrations
# PAYMOB_INTEGRATION_ID_CARD=12345
# PAYMOB_INTEGRATION_ID_WALLET=67890
